---
import { getCollection } from 'astro:content';
import BaseLayout from '../layouts/BaseLayout.astro';

// Fetch all articles from the markdown collection files dynamically
const allPosts = await getCollection('posts');
// Sort articles to show the newest ones first
const recentPosts = allPosts.sort((a, b) => new Date(b.data.date).getTime() - new Date(a.data.date).getTime());
---

<BaseLayout title="Home — Multi-Insight Portal">
	
	<!-- GOOGLE ADSENSE TOP SLOT -->
	<div class="w-full bg-gradient-to-r from-slate-100 via-slate-50 to-slate-100 border border-dashed border-slate-300 rounded-2xl p-4 text-center mb-10 shadow-sm relative overflow-hidden font-mono text-xs text-slate-400 select-none">
		[ ADVERTISEMENT BANNER PLACEHOLDER - ADSENSE ]
	</div>

	<div class="grid grid-cols-1 lg:grid-cols-3 gap-10">
		
		<!-- LEFT SIDE COLUMN: DYNAMIC MAIN BLOG CONTENT FEED -->
		<section class="lg:col-span-2 space-y-8">
			<h2 class="text-lg font-black uppercase tracking-wider text-slate-900 border-b-2 border-slate-900 pb-2 font-['Cabinet_Grotesk']">
				Latest Publications
			</h2>
			
			{recentPosts.length === 0 ? (
				<p class="text-slate-400">No content articles uploaded to the engine directory tracking systems yet.</p>
			) : (
				recentPosts.map((post) => (
					<article class="group bg-white rounded-2xl border border-slate-200/60 overflow-hidden flex flex-col md:flex-row gap-6 p-5 hover:border-blue-200 hover:shadow-[0_8px_30px_rgb(0,0,0,0.04)] transition-all duration-300">
						
						<!-- Visual Thumbnail Vector Blocks -->
						<div class="w-full md:w-2/5 bg-gradient-to-br from-blue-600 to-indigo-900 h-48 rounded-xl shrink-0 flex flex-col justify-between p-4 text-white/90 relative overflow-hidden shadow-sm">
							<span class="bg-white/20 backdrop-blur-md px-2 py-0.5 rounded text-[10px] font-bold uppercase tracking-wider self-start border border-white/10">
								{post.data.category}
							</span>
							<div class="font-bold text-sm tracking-tight text-white uppercase font-mono line-clamp-2">{post.data.title}</div>
						</div>

						<!-- Core Text Content Blocks -->
						<div class="w-full md:w-3/5 flex flex-col justify-between py-1">
							<div>
								<div class="flex items-center gap-2 mb-1.5">
									<span class="text-[10px] font-extrabold uppercase tracking-widest text-blue-600">{post.data.category}</span>
								</div>
								<h3 class="text-xl font-bold text-slate-900 tracking-tight leading-snug group-hover:text-blue-600 transition-colors">
									<a href={`/posts/${post.id}`}>
										{post.data.title}
									</a>
								</h3>
								<p class="text-slate-500 text-sm mt-2 line-clamp-2 font-normal leading-relaxed">
									{post.data.summary}
								</p>
							</div>
							
							<div class="text-[11px] font-medium text-slate-400 mt-4 flex items-center justify-between border-t border-slate-100 pt-2.5">
								<span>By {post.data.author}</span>
								<span>{post.data.date}</span>
							</div>
						</div>

					</article>
				))
			)}
		</section>

		<!-- RIGHT SIDE COLUMN: STICKY NAVIGATION AD SLOT -->
		<aside class="space-y-8">
			<div class="bg-white p-6 rounded-2xl border border-slate-200/60 shadow-sm">
				<h2 class="text-md font-black uppercase tracking-wider text-slate-900 border-b border-slate-100 pb-3 mb-4 font-['Cabinet_Grotesk']">Trending</h2>
				<p class="text-xs text-slate-500 font-medium">1. Global Inflation Index Baselines</p>
				<p class="text-xs text-slate-500 font-medium mt-2">2. Quantum Processing Protocols</p>
			</div>
			
			<div class="w-full bg-slate-100 border border-dashed border-slate-300 rounded-2xl py-32 text-center text-xs tracking-wider text-slate-400 font-mono select-none">
				[ GOOGLE ADSENSE SIDEBAR CONTAINER ]
			</div>
		</aside>

	</div>

</BaseLayout>