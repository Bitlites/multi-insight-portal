---
// Import your configured Tailwind v4 global stylesheet rules
import '../styles/global.css';

// Active topical navigation hubs
const categories = ["Home", "Current Affairs", "Technology", ""Science", "Finance", "Social Studies", "About Us", "Contact Us"];
---

<html lang="en">
	<head>
		<meta charset="utf-8" />
		<link rel="icon" type="image/svg+xml" href="/favicon.svg" />
		<meta name="viewport" content="width=device-width, initial-scale=1.0" />
		
		<!-- Premium Typography Fonts -->
		<link rel="preconnect" href="https://googleapis.com">
		<link rel="preconnect" href="https://gstatic.com" crossorigin>
		<link href="https://googleapis.com/css2?family=Cabinet+Grotesk:wght@800;900&family=Inter:wght@400;500;600;700&display=swap" rel="stylesheet">
		
		<title>Multi-Insight Portal — Global Trends & Analyses</title>
	</head>
	<body class="bg-[#F8FAFC] text-slate-900 font-['Inter',sans-serif] antialiased">

		<!-- TOP NEWS TICKER BANNER -->
		<div class="bg-blue-900 text-white text-xs font-semibold py-2 px-4 shadow-inner">
			<div class="max-w-7xl mx-auto flex items-center justify-between">
				<div class="flex items-center gap-2 overflow-hidden">
					<span class="bg-red-500 text-[10px] uppercase tracking-wider px-1.5 py-0.5 rounded font-bold animate-pulse">Live</span>
					<p class="truncate font-medium text-blue-100">Market Updates: Central banks signal shifting inflation baselines across global trade routes...</p>
				</div>
				<div class="hidden sm:block text-blue-200">Wednesday, July 15, 2026</div>
			</div>
		</div>

		<!-- BRANDING & LOGO AREA -->
		<header class="bg-white border-b border-slate-200/80 sticky top-0 z-50">
			<div class="max-w-7xl mx-auto px-4 py-5 flex flex-col items-center justify-between gap-4 md:flex-row">
				<a href="/" class="text-3xl font-['Cabinet_Grotesk',sans-serif] font-black tracking-tight text-slate-900 hover:text-blue-900 transition-colors">
					MULTI-INSIGHT <span class="text-blue-600">PORTAL</span>
				</a>
				
				<!-- MODERN PILL CATEGORY NAVIGATION -->
				<nav class="flex flex-wrap justify-center gap-2 text-xs font-bold tracking-wide uppercase">
					{categories.map((category) => (
						<a href={`/category/${category.toLowerCase()}`} class="px-3.5 py-2 rounded-full text-slate-600 bg-slate-50 hover:bg-blue-50 hover:text-blue-700 border border-slate-200/60 transition-all duration-200">
							{category}
						</a>
					))}
				</nav>
			</div>
		</header>

		<!-- MAIN APPLICATION WRAPPER -->
		<main class="max-w-7xl mx-auto px-4 py-8">
			
			<!-- GOOGLE ADSENSE LEADERBOARD SLOT -->
			<div class="w-full bg-gradient-to-r from-slate-100 via-slate-50 to-slate-100 border border-dashed border-slate-300 rounded-2xl p-4 text-center mb-10 shadow-sm relative overflow-hidden select-none">
				<div class="absolute inset-0 bg-[radial-gradient(#cbd5e1_1px,transparent_1px)] [background-size:16px_16px] opacity-30"></div>
				<span class="relative bg-white/80 backdrop-blur-sm border border-slate-200 px-3 py-1 rounded-full text-[10px] uppercase font-bold tracking-widest text-slate-400 font-mono">
					Advertisement • AdSense Leaderboard Slot
				</span>
				<div class="h-16 flex items-center justify-center text-xs font-medium text-slate-400 mt-2 font-mono">728 x 90 Responsive Container</div>
			</div>

			<!-- TWO-COLUMN CONTENT AREA DISPLAY -->
			<div class="grid grid-cols-1 lg:grid-cols-3 gap-10">
				<!-- LEFT & CENTER ARTICLE FEED COLUMN -->
				<section class="lg:col-span-2 space-y-8">
					<div class="flex items-center justify-between border-b-2 border-slate-900 pb-2.5">
						<h2 class="text-lg font-black uppercase tracking-wider text-slate-900 font-['Cabinet_Grotesk']">
							Latest Publications
						</h2>
						<span class="w-24 h-0.5 bg-blue-600 rounded-full"></span>
					</div>
					
					<!-- PREMIUM EDITORIAL ARTICLE CARD -->
					<article class="group bg-white rounded-2xl border border-slate-200/60 overflow-hidden flex flex-col md:flex-row gap-6 p-5 hover:border-blue-200 hover:shadow-[0_8px_30px_rgb(0,0,0,0.04)] transition-all duration-300">
						<!-- Content Thumbnail Vector Card -->
						<div class="w-full md:w-2/5 bg-gradient-to-br from-blue-600 to-indigo-900 h-52 rounded-xl shrink-0 flex flex-col justify-between p-4 text-white/90 relative overflow-hidden shadow-sm">
							<div class="absolute -right-10 -bottom-10 w-36 h-36 bg-white/10 rounded-full blur-xl group-hover:scale-125 transition-transform duration-500"></div>
							<span class="bg-white/20 backdrop-blur-md px-2.5 py-1 rounded-md text-[10px] font-bold uppercase tracking-wider self-start border border-white/10">Tech & Markets</span>
							<div class="font-['Cabinet_Grotesk'] font-bold text-lg leading-tight tracking-tight text-white line-clamp-3">QUANTUM BOUNDARIES</div>
							<div class="text-[10px] font-mono tracking-widest opacity-60">ANALYSIS_FILE_01</div>
						</div>

						<!-- Article Meta Information -->
						<div class="w-full md:w-3/5 flex flex-col justify-between py-1">
							<div>
								<div class="flex items-center gap-2 mb-2">
									<span class="text-[11px] font-extrabold uppercase tracking-widest text-blue-600">Technology</span>
									<span class="w-1 h-1 bg-slate-300 rounded-full"></span>
									<span class="text-xs font-semibold text-slate-400">Featured Study</span>
								</div>
								<h3 class="text-xl font-bold font-['Inter'] text-slate-900 tracking-tight leading-snug group-hover:text-blue-600 transition-colors cursor-pointer">
									The Future of Quantum Computing and Global Economies
								</h3>
								<p class="text-slate-500 text-sm mt-2.5 leading-relaxed line-clamp-3 font-normal">
									An in-depth look into how quantum mechanical phenomena are shifting computational models, altering cryptographic security baselines, and breaking conventional economic boundaries in global markets.
								</p>
							</div>
							
							<!-- Author Details Card Footer -->
							<div class="text-[11px] font-medium text-slate-400 mt-4 flex items-center justify-between border-t border-slate-100 pt-3">
								<div class="flex items-center gap-2">
									<div class="w-5 h-5 rounded-full bg-slate-200 border border-slate-300 flex items-center justify-center font-bold text-[9px] text-slate-500">MI</div>
									<span>By Editorial Team</span>
								</div>
								<span>5 min read • July 15, 2026</span>
							</div>
						</div>
					</article>
				</section>
				<!-- RIGHT SIDEBAR CONTEXT NAVIGATION PANEL -->
				<aside class="space-y-8">
					
					<!-- TRENDING HOT TOPICS CONTAINER -->
					<div class="bg-white p-6 rounded-2xl border border-slate-200/60 shadow-sm relative overflow-hidden">
						<h2 class="text-md font-black uppercase tracking-wider text-slate-900 border-b border-slate-100 pb-3.5 mb-5 font-['Cabinet_Grotesk']">
							Trending Topics
						</h2>
						<ul class="space-y-5">
							<li class="group cursor-pointer flex gap-3.5 items-start">
								<span class="text-2xl font-black text-slate-200 font-['Cabinet_Grotesk'] group-hover:text-blue-600 transition-colors leading-none">01</span>
								<div>
									<h4 class="text-sm font-semibold text-slate-800 leading-tight group-hover:underline">Deep Ocean Geography Discoveries</h4>
									<span class="text-[10px] text-slate-400 font-bold uppercase tracking-wider mt-1 block">Science</span>
								</div>
							</li>
							<li class="group cursor-pointer flex gap-3.5 items-start">
								<span class="text-2xl font-black text-slate-200 font-['Cabinet_Grotesk'] group-hover:text-blue-600 transition-colors leading-none">02</span>
								<div>
									<h4 class="text-sm font-semibold text-slate-800 leading-tight group-hover:underline">Post-Election Global Trade Policies</h4>
									<span class="text-[10px] text-slate-400 font-bold uppercase tracking-wider mt-1 block">Politics</span>
								</div>
							</li>
							<li class="group cursor-pointer flex gap-3.5 items-start">
								<span class="text-2xl font-black text-slate-200 font-['Cabinet_Grotesk'] group-hover:text-blue-600 transition-colors leading-none">03</span>
								<div>
									<h4 class="text-sm font-semibold text-slate-800 leading-tight group-hover:underline">Understanding Market Inflation Cycles</h4>
									<span class="text-[10px] text-slate-400 font-bold uppercase tracking-wider mt-1 block">Economy</span>
								</div>
							</li>
						</ul>
					</div>

					<!-- RECTANGLE BLOCK SIDEBAR DISPLAY AD -->
					<div class="w-full bg-gradient-to-b from-slate-100 to-slate-50 border border-dashed border-slate-300 rounded-2xl p-6 text-center shadow-sm relative overflow-hidden select-none">
						<div class="absolute inset-0 bg-[radial-gradient(#cbd5e1_1px,transparent_1px)] [background-size:16px_16px] opacity-30"></div>
						<span class="relative bg-white/80 backdrop-blur-sm border border-slate-200 px-3 py-1 rounded-full text-[10px] uppercase font-bold tracking-widest text-slate-400 font-mono">
							In-Feed Display Ad
						</span>
						<div class="h-64 flex items-center justify-center text-xs font-medium text-slate-400 mt-4 font-mono">300 x 250 Medium Rectangle</div>
					</div>
				</aside>

			</div>
		</main>

		<!-- SYSTEM LEGAL LINKAGE FOOTER -->
		<footer class="bg-slate-950 text-slate-400 text-xs mt-24 py-12 border-t border-slate-900">
			<div class="max-w-7xl mx-auto px-4 flex flex-col md:flex-row justify-between items-center gap-6">
				<div class="flex flex-col items-center md:items-start gap-1">
					<p class="font-bold text-slate-200 text-sm tracking-tight font-['Cabinet_Grotesk']">MULTI-INSIGHT PORTAL</p>
					<p>&copy; 2026 Multi-Insight Portal. Content curation built on static infrastructure.</p>
				</div>
				<div class="flex flex-wrap justify-center gap-6 font-semibold">
					<a href="/privacy-policy" class="hover:underline hover:text-white transition-colors">Privacy Policy</a>
					<a href="/about" class="hover:underline hover:text-white transition-colors">About Us</a>
					<a href="/terms" class="hover:underline hover:text-white transition-colors">Terms of Service</a>
				</div>
			</div>
		</footer>

	</body>
</html>
