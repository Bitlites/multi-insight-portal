---
// Import the Tailwind stylesheet generated during setup
import '../styles/global.css';

const categories = ["Science", "Technology", "History", "Geography", "Economy", "Politics"];
---

<html lang="en">
	<head>
		<meta charset="utf-8" />
		<link rel="icon" type="image/svg+xml" href="/favicon.svg" />
		<meta name="viewport" content="width=device-width, initial-scale=1.0" />
		<title>Multi-Insight Portal</title>
	</head>
	<body class="bg-slate-50 text-slate-900 font-sans antialiased">

		<!-- BRANDING & MAIN CATEGORY NAVIGATION -->
		<header class="bg-white border-b border-slate-200 sticky top-0 z-50 shadow-sm">
			<div class="max-w-7xl mx-auto px-4 py-4 flex flex-col md:flex-row items-center justify-between gap-4">
				<a href="/" class="text-3xl font-black tracking-tight text-blue-800">MULTI-INSIGHT PORTAL</a>
				<nav class="flex flex-wrap justify-center gap-6 text-sm font-bold tracking-wide uppercase text-slate-600">
					{categories.map((category) => (
						<a href={`/category/${category.toLowerCase()}`} class="hover:text-blue-800 transition-colors duration-200">
							{category}
						</a>
					))}
				</nav>
			</div>
		</header>

		<!-- MAIN CONTAINER -->
		<main class="max-w-7xl mx-auto px-4 py-8">
			
			<!-- TOP LEADERBOARD AD SLOT (CRITICAL FOR MONETIZATION) -->
			<div class="w-full bg-slate-200 border border-slate-300 rounded-md text-center py-8 mb-8 text-xs tracking-wider text-slate-500 font-mono select-none">
				[ ADVERTISEMENT BANNER PLACEHOLDER - GOOGLE ADSENSE LEADERBOARD ]
			</div>

			<!-- TWO-COLUMN CONTENT AREA -->
			<div class="grid grid-cols-1 lg:grid-cols-3 gap-8">
				
				<!-- MAIN FEEDS: ARTICLES SECTION (LEFT & CENTER COLUMN) -->
				<section class="lg:col-span-2 space-y-8">
					<h2 class="text-xl font-extrabold uppercase tracking-wider text-slate-800 border-b-4 border-blue-800 pb-2">
						Latest Insights
					</h2>
					
					<!-- Prototype Article Display Card -->
					<article class="bg-white rounded-xl shadow-sm border border-slate-100 overflow-hidden flex flex-col md:flex-row gap-6 p-5 hover:shadow-md transition-shadow duration-200">
						<!-- Content Thumbnail Image Placeholder -->
						<div class="w-full md:w-1/3 bg-slate-300 h-48 rounded-lg shrink-0 flex items-center justify-center text-slate-400 font-medium">Image Preview</div>
						<div class="w-full md:w-2/3 flex flex-col justify-between">
							<div>
								<span class="text-xs font-bold uppercase tracking-wider text-blue-700">Technology</span>
								<h3 class="text-xl font-bold mt-1 mb-2 hover:text-blue-800 transition-colors cursor-pointer">
									The Future of Quantum Computing and Global Economies
								</h3>
								<p class="text-slate-600 text-sm line-clamp-3 leading-relaxed">
									An in-depth look into how quantum mechanical phenomena are shifting computational models, altering cryptographic security baselines, and breaking conventional economic boundaries in global markets.
								</p>
							</div>
							<div class="text-xs text-slate-400 mt-4 flex items-center gap-2">
								<span>July 15, 2026</span>
								<span>•</span>
								<span>5 min read</span>
							</div>
						</div>
					</article>
				</section>

				<!-- NAVIGATION SIDEBAR (RIGHT COLUMN) -->
				<aside class="space-y-6">
					<!-- Trending Widget Box -->
					<div class="bg-white p-5 rounded-xl shadow-sm border border-slate-100">
						<h2 class="text-lg font-bold uppercase tracking-wider text-slate-800 border-b border-slate-200 pb-3 mb-4">
							Trending Topics
						</h2>
						<ul class="space-y-4 text-sm font-semibold text-slate-700">
							<li class="hover:text-blue-800 transition-colors cursor-pointer flex gap-2">
								<span class="text-blue-700">1.</span> Deep Ocean Geography Discoveries
							</li>
							<li class="hover:text-blue-800 transition-colors cursor-pointer flex gap-2">
								<span class="text-blue-700">2.</span> Post-Election Global Trade Policies
							</li>
							<li class="hover:text-blue-800 transition-colors cursor-pointer flex gap-2">
								<span class="text-blue-700">3.</span> Understanding Market Inflation Cycles
							</li>
						</ul>
					</div>

					<!-- IN-FEED SIDEBAR AD SLOT -->
					<div class="w-full bg-slate-200 border border-slate-300 rounded-xl text-center py-28 text-xs tracking-wider text-slate-500 font-mono select-none">
						[ GOOGLE ADSENSE SIDEBAR DISPLAY AD ]
					</div>
				</aside>

			</div>
		</main>

		<!-- FOOTER LINKS WITH REQUIRED LEGAL POLICIES -->
		<footer class="bg-slate-900 text-slate-400 text-sm mt-16 py-12 border-t border-slate-800">
			<div class="max-w-7xl mx-auto px-4 flex flex-col md:flex-row justify-between items-center gap-6">
				<p>&copy; 2026 Multi-Insight Portal. All rights reserved.</p>
				<div class="flex flex-wrap justify-center gap-6 font-medium">
					<a href="/privacy-policy" class="hover:underline hover:text-white transition-colors">Privacy Policy</a>
					<a href="/about" class="hover:underline hover:text-white transition-colors">About Us</a>
					<a href="/terms" class="hover:underline hover:text-white transition-colors">Terms of Service</a>
				</div>
			</div>
		</footer>

	</body>
</html>
