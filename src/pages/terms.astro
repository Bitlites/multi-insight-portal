---
import { getCollection } from 'astro:content';
import BaseLayout from '../layouts/BaseLayout.astro';

const allPosts = await getCollection('posts');
const sortedPosts = allPosts.sort((a, b) => new Date(b.data.date).getTime() - new Date(a.data.date).getTime());
const trendingPosts = sortedPosts.slice(0, 5);
---

<BaseLayout title="Terms of Service — Multi-Insight Portal">

  <!-- TOP GOOGLE ADSENSE SLOT -->
  <div class="w-full bg-gradient-to-r from-slate-100 via-slate-50 to-slate-100 dark:from-slate-900 dark:via-slate-900 dark:to-slate-900 border border-dashed border-slate-300 dark:border-slate-800 rounded-2xl p-4 text-center mb-10 shadow-sm font-mono text-xs text-slate-400 select-none">
    [ GOOGLE ADSENSE BANNER — TERMS TOP SLOT ]
  </div>

  <div class="grid grid-cols-1 md:grid-cols-3 lg:grid-cols-4 gap-8">
    
    <!-- COLUMN 1: LEFT VERTICAL AD CONTAINER -->
    <aside class="hidden lg:block lg:col-span-1 self-start sticky top-24">
      <div class="w-full bg-gradient-to-b from-slate-100 to-slate-50 dark:from-slate-900 dark:to-slate-950 border border-dashed border-slate-300 dark:border-slate-800 rounded-2xl py-64 text-center text-xs tracking-wider text-slate-400 font-mono select-none">
        [ GOOGLE ADSENSE <br/> LEFT VERTICAL <br/> SKYSCRAPER AD ]
      </div>
    </aside>

    <!-- COLUMNS 2 & 3: MAIN LEGAL COMPLIANCE WRAPPER -->
    <div class="md:col-span-2 lg:col-span-2 space-y-6">
      <div class="bg-white dark:bg-slate-900 border border-slate-200/60 dark:border-slate-800/80 rounded-2xl p-6 md:p-8 shadow-sm">
        
        <div class="mb-6 border-b border-slate-150 dark:border-slate-800 pb-4">
          <span class="text-xs font-extrabold uppercase tracking-widest text-blue-600 dark:text-blue-400">Legal Agreement</span>
          <h1 class="text-3xl md:text-4xl font-black font-['Cabinet_Grotesk'] tracking-tight text-slate-900 dark:text-white mt-1">
            Terms of Service
          </h1>
          <p class="text-slate-400 text-xs mt-2 font-mono">Last Updated: July 16, 2026</p>
        </div>

        <div class="prose prose-slate dark:prose-invert max-w-none text-slate-700 dark:text-slate-300 text-sm md:text-[15px] leading-relaxed space-y-6">
          <p>Welcome to <strong>Multi-Insight Portal</strong>. By accessing our platform networks and consuming our static analytical text streams, you acknowledge full structural compliance with the following operational terms.</p>
          
          <h2 class="text-lg font-black font-['Cabinet_Grotesk'] text-slate-900 dark:text-white uppercase pt-2">1. Intellectual Property Bounds</h2>
          <p>Unless otherwise stated, Multi-Insight Portal and/or its editorial contributors own the intellectual property rights for all data models, article summaries, and textual structures posted directly to this domain. All rights are reserved.</p>

          <h2 class="text-lg font-black font-['Cabinet_Grotesk'] text-slate-900 dark:text-white uppercase pt-2">2. User Content Restrictions</h2>
          <p>You are strictly restricted from copying, republishing, selling, or distributing our parsed data files into external commercial database systems or training loops without explicit prior written authorization from our compliance board.</p>
        </div>
      </div>
    </div>

    <!-- COLUMN 4: RIGHT PANEL TRENDING SIDEBAR -->
    <aside class="md:col-span-1 lg:col-span-1 self-start md:sticky md:top-24">
      <div class="bg-white dark:bg-slate-900 p-6 rounded-2xl border border-slate-200/60 dark:border-slate-800/60 shadow-sm relative overflow-hidden">
        <h2 class="text-md font-black uppercase tracking-wider text-slate-900 dark:text-white border-b border-slate-100 dark:border-slate-800 pb-3.5 mb-5 font-['Cabinet_Grotesk'] flex items-center gap-2">
          <span class="text-xl select-none">🔥</span> Trending
        </h2>
        <ul class="space-y-5">
          {trendingPosts.map((p, index) => (
            <li class="group cursor-pointer flex gap-3.5 items-start">
              <span class="text-xl font-black text-slate-200 dark:text-slate-700 group-hover:text-blue-600 dark:group-hover:text-blue-400 transition-colors leading-none font-['Cabinet_Grotesk']">
                {String(index + 1).padStart(2, '0')}
              </span>
              <h4 class="text-xs font-bold text-slate-800 dark:text-slate-200 leading-snug group-hover:underline">
                <a href={`/posts/${p.id}`}>{p.data.title}</a>
              </h4>
            </li>
          ))}
        </ul>
      </div>
    </aside>
  </div>

  <!-- BOTTOM FULL HORIZONTAL DISPLAY SLOT -->
  <div class="w-full bg-gradient-to-r from-slate-100 via-slate-50 to-slate-100 dark:from-slate-900 dark:via-slate-900 dark:to-slate-900 border border-dashed border-slate-300 dark:border-slate-800 rounded-2xl p-5 text-center mt-12 shadow-sm font-mono text-xs text-slate-400 select-none">
    [ GOOGLE ADSENSE — FOOTER HIGH-IMPRESSION NATIVE DISPLAY AD SLOT ]
  </div>
</BaseLayout>