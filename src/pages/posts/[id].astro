---
import { getCollection, render } from 'astro:content';
import BaseLayout from '../../layouts/BaseLayout.astro';

export async function getStaticPaths() {
  const posts = await getCollection('posts');
  return posts.map(post => ({
    params: { id: post.id },
    props: { post },
  }));
}

const { post } = Astro.props;
const { Content, headings } = await render(post);

// Filter to grab only primary section subheadings (### anchors) for the roadmap mapping
const tocHeadings = headings.filter(h => h.depth === 3);

const allPosts = await getCollection('posts');
const sortedPosts = allPosts.sort((a, b) => new Date(b.data.date).getTime() - new Date(a.data.date).getTime());
const trendingPosts = sortedPosts.slice(0, 5);

const targetCategories = ['current-affairs', 'technology', 'science', 'finance', 'social-studies'];
const recommendedPosts = targetCategories.map(catId => {
  return sortedPosts.find(p => p.data.category.toLowerCase() === catId);
}).filter(Boolean);

// DYNAMIC ZERO-HARDCODING RESOLVER: Detects localhost, deployment branch previews, or custom production domains
const requestUrl = Astro.url;
const absolutePostUrl = `${requestUrl.origin}/posts/${post.id}`;
const articleTitle = `${post.data.title} — Multi-Insight Portal`;

// PRE-ENCODED ENDPOINTS: Calculated safely using native frontmatter string interpolation vectors
const xShareUrl = `https://x.com{encodeURIComponent(absolutePostUrl)}&text=${encodeURIComponent(articleTitle)}`;
const linkedinShareUrl = `https://linkedin.com{encodeURIComponent(absolutePostUrl)}`;
const whatsappShareUrl = `https://whatsapp.com{encodeURIComponent(articleTitle + ' - ' + absolutePostUrl)}`;
const facebookShareUrl = `https://facebook.com{encodeURIComponent(absolutePostUrl)}`;
const redditShareUrl = `https://reddit.com{encodeURIComponent(absolutePostUrl)}&title=${encodeURIComponent(articleTitle)}`;
const pinterestShareUrl = `https://pinterest.com{encodeURIComponent(absolutePostUrl)}&description=${encodeURIComponent(articleTitle)}`;
---

<BaseLayout title={`${post.data.title} — Multi-Insight Portal`}>

  <!-- GOOGLE ADSENSE POST TOP BANNER -->
  <div class="w-full bg-gradient-to-r from-slate-100 via-slate-50 to-slate-100 dark:from-slate-900 dark:via-slate-900 dark:to-slate-900 border border-dashed border-slate-300 dark:border-slate-800 rounded-2xl p-4 text-center mb-10 shadow-sm font-mono text-xs text-slate-400 select-none">
    [ GOOGLE ADSENSE BANNER — POST TOP SLOT ]
  </div>

  <!-- 4-COLUMN PATTERN INTERACTIVE MATRIX GRID -->
  <div class="grid grid-cols-1 md:grid-cols-3 lg:grid-cols-4 gap-8">

    <!-- COLUMN 1: LEFT VERTICAL AD CONTAINER (Purely Ads) -->
    <aside class="hidden lg:block lg:col-span-1 self-start sticky top-24">
      <div class="w-full bg-gradient-to-b from-slate-100 to-slate-50 dark:from-slate-900 dark:to-slate-950 border border-dashed border-slate-300 dark:border-slate-800 rounded-2xl py-64 text-center text-xs tracking-wider text-slate-400 font-mono select-none">
        [ GOOGLE ADSENSE <br/> LEFT VERTICAL <br/> SKYSCRAPER AD ]
      </div>
    </aside>

    <!-- COLUMNS 2 & 3: MAIN CORE TEXT CONTENT CARD SECTION -->
    <div class="md:col-span-2 lg:col-span-2">
      <article class="bg-white dark:bg-slate-900 border border-slate-200/60 dark:border-slate-800/80 rounded-2xl p-5 md:p-8 shadow-sm space-y-6">
        
        <!-- ARTICLE HERO HEADER METADATA -->
        <div class="border-b border-slate-100 dark:border-slate-800 pb-5">
          <div class="flex items-center gap-2 mb-3">
            <a href={`/category/${post.data.category.toLowerCase()}`} class="text-xs font-extrabold uppercase tracking-widest text-blue-600 dark:text-blue-400 hover:underline">
              {post.data.category}
            </a>
            <span class="text-slate-300 dark:text-slate-700">•</span>
            <span class="text-xs font-medium text-slate-400 dark:text-slate-500">{post.data.date}</span>
          </div>
          
          <h1 class="text-2xl md:text-4xl font-black font-['Cabinet_Grotesk'] tracking-tight text-slate-900 dark:text-white leading-tight mb-4">
            {post.data.title}
          </h1>
          
          <div class="border-l-4 border-blue-600 dark:border-blue-500 pl-4 py-1 my-4">
            <p class="text-slate-600 dark:text-slate-300 text-sm md:text-base leading-relaxed font-medium italic">
              {post.data.summary}
            </p>
          </div>
        </div>

        <!-- INLINE IN-CONTENT TABLE OF CONTENTS ROADMAP -->
        {tocHeadings.length > 0 && (
          <div class="bg-slate-50 dark:bg-slate-950 border border-slate-200/80 dark:border-slate-800 rounded-xl p-5 my-4">
            <h3 class="text-xs font-bold uppercase tracking-wider text-slate-900 dark:text-white pb-2.5 mb-3 border-b border-slate-200 dark:border-slate-800 font-mono flex items-center gap-1.5">
              📋 Quick Article Navigation Roadmap
            </h3>
            <nav class="flex flex-col gap-y-2.5 text-[13px]">
              {tocHeadings.map(h => (
                <a 
                  href={`#${h.slug}`} 
                  class="text-slate-600 dark:text-slate-400 hover:text-blue-600 dark:hover:text-blue-400 font-semibold transition-colors flex items-center gap-2 before:content-['•'] before:text-blue-500 before:font-bold"
                >
                  {h.text}
                </a>
              ))}
            </nav>
          </div>
        )}

        <!-- RE-BALANCED MID-POST AD PLACEMENT -->
        <div class="w-full bg-slate-50 dark:bg-slate-950 border border-dashed border-slate-200 dark:border-slate-800 rounded-xl p-4 text-center my-6 font-mono text-[10px] text-slate-400 select-none">
          [ GOOGLE ADSENSE — MID-POST INLINE AD CONTROLLER ]
        </div>

        <!-- MAIN BODY RICH TEXT CONTENT LAYER -->
        <div class="prose prose-slate dark:prose-invert max-w-none 
          prose-headings:font-['Cabinet_Grotesk'] prose-headings:font-black prose-headings:tracking-tight prose-headings:text-slate-900 dark:prose-headings:text-white
          prose-h2:text-2xl prose-h2:mt-10 prose-h2:mb-4 prose-h2:border-b prose-h2:border-slate-100 dark:prose-h2:border-slate-800 prose-h2:pb-2
          prose-h3:text-lg prose-h3:mt-8 prose-h3:mb-3
          prose-p:text-sm md:prose-p:text-[16px] prose-p:leading-relaxed prose-p:text-slate-700 dark:prose-p:text-slate-300 prose-p:mb-6
          prose-blockquote:not-italic prose-blockquote:border-l-4 prose-blockquote:border-blue-600 dark:prose-blockquote:border-blue-500 prose-blockquote:bg-slate-50 dark:prose-blockquote:bg-slate-950/40 prose-blockquote:px-5 prose-blockquote:py-4 prose-blockquote:rounded-r-xl prose-blockquote:my-8 prose-blockquote:shadow-sm
          prose-ul:space-y-3 prose-ul:my-6 prose-ul:block prose-ul:list-disc prose-ul:pl-5
          prose-li:text-slate-600 dark:prose-li:text-slate-400 prose-li:text-sm md:prose-li:text-[15px]
          prose-ol:space-y-3 prose-ol:my-6 prose-ol:block prose-ol:list-decimal prose-ol:pl-5
          prose-hr:border-slate-200 dark:prose-hr:border-slate-800 prose-hr:my-8">
          <Content />
        </div>

        <!-- COMPACT NATIVE SYSTEM SHARING HUB -->
        <div class="border-t border-slate-100 dark:border-slate-800 pt-6 mt-10 space-y-4">
          <h3 class="text-xs font-bold uppercase tracking-wider text-slate-800 dark:text-slate-200 font-mono flex items-center gap-1.5">
            📢 Enjoyed this analysis? Share with your network
          </h3>
          
          <div class="flex flex-wrap items-center gap-2">
            <!-- Unified System Share Trigger -->
            <button id="native-system-share-btn" class="flex items-center justify-center gap-2 bg-slate-900 hover:bg-black text-white font-bold text-xs uppercase tracking-wider px-5 py-3 rounded-lg shadow-sm transition-colors cursor-pointer border border-slate-800">
              <svg xmlns="http://w3.org" fill="none" viewBox="0 0 24 24" stroke-width="2.5" stroke="currentColor" class="w-4 h-4"><path stroke-linecap="round" stroke-linejoin="round" d="M7.217 10.907a2.25 2.25 0 1 0 0 2.186m0-2.186c.18.324.283.696.283 1.093s-.103.77-.283 1.093m0-2.186 9.566-5.314m-9.566 7.5 9.566 5.314m0 0a2.25 2.25 0 1 0 3.935 2.186 2.25 2.25 0 0 0-3.935-2.186Zm0-12.814a2.25 2.25 0 1 0 3.933-2.185 2.25 2.25 0 0 0-3.933 2.185Z" /></svg>
              <span>Share Article</span>
            </button>

            <!-- Copy Link Button Fallback -->
            <button id="inline-copy-btn" class="flex items-center justify-center gap-1.5 bg-slate-100 dark:bg-slate-800 text-slate-700 dark:text-slate-300 font-bold text-[11px] uppercase tracking-wider px-3.5 py-3 rounded-lg shadow-sm transition-colors cursor-pointer border border-slate-200 dark:border-slate-700 sm:ml-auto">
              <svg xmlns="http://w3.org" fill="none" viewBox="0 0 24 24" stroke-width="2.5" stroke="currentColor" class="w-3.5 h-3.5"><path stroke-linecap="round" stroke-linejoin="round" d="M15.666 3.888A2.25 2.25 0 0 0 13.5 2.25h-3c-1.03 0-1.9.693-2.166 1.638m7.332 0c.055.194.084.4.084.612v0a.75.75 0 0 1-.75.75H9a.75.75 0 0 1-.75-.75v0c0-.212.03-.418.084-.612m7.332 0c.646.049 1.288.11 1.927.184 1.1.128 1.907 1.077 1.907 2.185V19.5a2.25 2.25 0 0 1-2.25 2.25H6.75A2.25 2.25 0 0 1 4.5 19.5V6.744c0-1.11.807-2.057 1.907-2.185a48.507 48.507 0 0 1 1.927-.184" /></svg>
              <span id="inline-copy-text">Copy Link</span>
            </button>
          </div>
        </div>

        <script is:inline>
          (function() {
            function initSharingUtilities() {
              const shareBtn = document.getElementById('native-system-share-btn');
              const copyBtn = document.getElementById('inline-copy-btn');
              const copyText = document.getElementById('inline-copy-text');
              
              const cleanUrl = window.location.origin + window.location.pathname;
              const pageTitle = document.title;

              // Native System Sharing Menu Hook
              if (shareBtn) {
                shareBtn.onclick = async () => {
                  if (navigator.share) {
                    try {
                      await navigator.share({
                        title: pageTitle,
                        url: cleanUrl
                      });
                    } catch (err) {
                      console.log('System share dismissed or closed');
                    }
                  } else {
                    // Fallback to clipboard if browser doesn't support Web Share API
                    navigator.clipboard.writeText(cleanUrl);
                    alert('Sharing link copied to clipboard!');
                  }
                };
              }

              // Standard Clipboard Copy Hook
              if (copyBtn && copyText) {
                copyBtn.onclick = (e) => {
                  e.preventDefault();
                  navigator.clipboard.writeText(cleanUrl).then(() => {
                    copyText.innerText = "Copied!";
                    setTimeout(() => { copyText.innerText = "Copy Link"; }, 2000);
                  }).catch(err => console.error(err));
                };
              }
            }

            if (document.readyState === 'loading') {
              document.addEventListener('DOMContentLoaded', initSharingUtilities);
            } else {
              initSharingUtilities();
            }
            document.addEventListener('astro:after-swap', initSharingUtilities);
          })();
        </script>
      </article>
    </div>

    <!-- COLUMN 4: RIGHT SECTION SIDEBAR COLUMN -->
    <aside class="md:col-span-1 lg:col-span-1 space-y-8 self-start md:sticky md:top-24">
      
      <!-- TRENDING COMPONENT -->
      <div class="bg-white dark:bg-slate-900 p-6 rounded-2xl border border-slate-200/60 dark:border-slate-800/60 shadow-sm relative overflow-hidden">
        <h2 class="text-md font-black uppercase tracking-wider text-slate-900 dark:text-white border-b border-slate-100 dark:border-slate-800 pb-3.5 mb-5 font-['Cabinet_Grotesk'] flex items-center gap-2">
          <span class="text-xl select-none">🔥</span> Trending
        </h2>
        <ul class="space-y-5">
          {trendingPosts.map((p, index) => (
            <li class="group cursor-pointer flex gap-3.5 items-start">
              <span class="text-xl font-black text-slate-200 dark:text-slate-700 group-hover:text-blue-600 dark:group-hover:text-blue-400 transition-colors leading-none font-['Cabinet_Grotesk']">
                {String(index + 1).padStart(2, '0')}
              </span>
              <div class="space-y-0.5">
                <h4 class="text-xs font-bold text-slate-800 dark:text-slate-200 leading-snug group-hover:underline">
                  <a href={`/posts/${p.id}`}>{p.data.title}</a>
                </h4>
                <span class="text-[9px] text-blue-600 dark:text-blue-400 font-extrabold uppercase tracking-widest block pt-0.5">
                  {p.data.category}
                </span>
              </div>
            </li>
          ))}
        </ul>
      </div>

      <!-- RECOMMENDED MODULE -->
      <div class="bg-white dark:bg-slate-900 p-6 rounded-2xl border border-slate-200/60 dark:border-slate-800/60 shadow-sm relative overflow-hidden">
        <h2 class="text-md font-black uppercase tracking-wider text-slate-900 dark:text-white border-b border-slate-100 dark:border-slate-800 pb-3.5 mb-5 font-['Cabinet_Grotesk'] flex items-center gap-2">
          <span class="text-xl select-none">💡</span> Recommended For You
        </h2>
        <ul class="space-y-4">
          {recommendedPosts.map((p) => (
            <li class="group border-b border-slate-50 dark:border-slate-800/60 pb-3 last:border-0 last:pb-0">
              <h4 class="text-xs font-bold text-slate-800 dark:text-slate-200 leading-snug group-hover:text-blue-600 dark:group-hover:text-blue-400">
                <a href={`/posts/${p.id}`}>{p.data.title}</a>
              </h4>
              <span class="text-[9px] text-slate-400 dark:text-slate-500 font-medium block mt-1 uppercase font-mono">
                {p.data.category}
              </span>
            </li>
          ))}
        </ul>
      </div>

      <!-- RIGHT SIDEBAR IN-FEED ADS CONTAINER -->
      <div class="w-full bg-gradient-to-b from-slate-100 to-slate-50 dark:from-slate-900 dark:to-slate-950 border border-dashed border-slate-300 dark:border-slate-800 rounded-2xl py-32 text-center text-xs tracking-wider text-slate-400 font-mono select-none">
        [ GOOGLE ADSENSE SIDEBAR BANNER ]
      </div>
    </aside>
  </div>

  <!-- BOTTOM FULL HORIZONTAL GOOGLE ADSENSE FOOTER SLOT -->
  <div class="w-full bg-gradient-to-r from-slate-100 via-slate-50 to-slate-100 dark:from-slate-900 dark:via-slate-900 dark:to-slate-900 border border-dashed border-slate-300 dark:border-slate-800 rounded-2xl p-5 text-center mt-12 shadow-sm font-mono text-xs text-slate-400 select-none">
    [ GOOGLE ADSENSE — FOOTER HIGH-IMPRESSION NATIVE DISPLAY AD SLOT ]
  </div>

</BaseLayout>

<style is:global>
  html {
    scroll-behavior: smooth;
    scroll-padding-top: 100px;
  }
  /* System-forced paragraph override rules to lock spacing bounds */
  .prose p {
    margin-bottom: 1.5rem !important;
    display: block !important;
  }
  .prose h3 {
    margin-top: 2.25rem !important;
    margin-bottom: 1rem !important;
    display: block !important;
  }
  .prose ul li, .prose ol li {
    margin-bottom: 0.75rem !important;
  }
</style>