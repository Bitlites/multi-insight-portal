---
import { getCollection } from 'astro:content';
import BaseLayout from '../layouts/BaseLayout.astro';

// Fetch all publications globally to keep sidebar channels synced
const allPosts = await getCollection('posts');
const sortedPosts = allPosts.sort((a, b) => new Date(b.data.date).getTime() - new Date(a.data.date).getTime());
const trendingPosts = sortedPosts.slice(0, 5);

// Dynamic recommended links engine loop
const targetCategories = ['current-affairs', 'technology', 'science', 'finance', 'social-studies'];
const recommendedPosts = targetCategories.map(catId => {
  return sortedPosts.find(p => p.data.category.toLowerCase() === catId);
}).filter(Boolean);
---

<BaseLayout title="Connect With Us — Multi-Insight Portal">

  <!-- GOOGLE ADSENSE TOP SLOT BANNER -->
  <div class="w-full bg-gradient-to-r from-slate-100 via-slate-50 to-slate-100 dark:from-slate-900 dark:via-slate-900 dark:to-slate-900 border border-dashed border-slate-300 dark:border-slate-800 rounded-2xl p-4 text-center mb-10 shadow-sm font-mono text-xs text-slate-400 select-none">
    [ GOOGLE ADSENSE BANNER — CONTACT US TOP SLOT ]
  </div>

  <!-- 4-COLUMN STRUCTURAL PATTERN MATRIX GRID -->
  <div class="grid grid-cols-1 md:grid-cols-3 lg:grid-cols-4 gap-8">
    
    <!-- COLUMN 1: LEFT VERTICAL AD CONTAINER -->
    <aside class="hidden lg:block lg:col-span-1 self-start sticky top-24">
      <div class="w-full bg-gradient-to-b from-slate-100 to-slate-50 dark:from-slate-900 dark:to-slate-950 border border-dashed border-slate-300 dark:border-slate-800 rounded-2xl py-64 text-center text-xs tracking-wider text-slate-400 font-mono select-none">
        [ GOOGLE ADSENSE <br/> LEFT VERTICAL <br/> SKYSCRAPER AD ]
      </div>
    </aside>

    <!-- COLUMNS 2 & 3: MAIN CARD CONTENT CONTAINER WITH RESPONSIVE FORM -->
    <div class="md:col-span-2 lg:col-span-2 space-y-6">
      <div class="bg-white dark:bg-slate-900 border border-slate-200/60 dark:border-slate-800/80 rounded-2xl p-6 md:p-8 shadow-sm">
        
        <!-- COMPLIANCE TITLE HEADER -->
        <div class="mb-6 border-b border-slate-150 dark:border-slate-800 pb-4">
          <span class="text-xs font-extrabold uppercase tracking-widest text-blue-600 dark:text-blue-400">Communication Desk</span>
          <h1 class="text-3xl md:text-4xl font-black font-['Cabinet_Grotesk'] tracking-tight text-slate-900 dark:text-white mt-1">
            Connect With Us
          </h1>
          <p class="text-slate-400 text-xs mt-1.5">Have an editorial inquiry or general insight feedback loop? Drop our desk a message.</p>
        </div>

        <!-- INTERACTIVE CONTACT FORM WORKSPACE -->
        <form class="space-y-4" onsubmit="event.preventDefault(); alert('Message logged successfully into static simulation container!');">
          <div class="grid grid-cols-1 sm:grid-cols-2 gap-4">
            <div>
              <label class="block text-xs font-bold text-slate-500 uppercase tracking-wider mb-1.5 font-mono">Your Name</label>
              <input type="text" required placeholder="John Doe" class="w-full bg-slate-50 dark:bg-slate-950 border border-slate-200 dark:border-slate-800 rounded-xl px-3.5 py-2.5 text-xs text-slate-900 dark:text-white focus:outline-none focus:border-blue-500 transition-colors font-medium placeholder-slate-400" />
            </div>
            <div>
              <label class="block text-xs font-bold text-slate-500 uppercase tracking-wider mb-1.5 font-mono">Email Address</label>
              <input type="email" required placeholder="name@domain.com" class="w-full bg-slate-50 dark:bg-slate-950 border border-slate-200 dark:border-slate-800 rounded-xl px-3.5 py-2.5 text-xs text-slate-900 dark:text-white focus:outline-none focus:border-blue-500 transition-colors font-medium placeholder-slate-400" />
            </div>
          </div>
          <div>
            <label class="block text-xs font-bold text-slate-500 uppercase tracking-wider mb-1.5 font-mono">Inquiry Subject</label>
            <input type="text" required placeholder="Editorial Feedback / Ad Sponsorships" class="w-full bg-slate-50 dark:bg-slate-950 border border-slate-200 dark:border-slate-800 rounded-xl px-3.5 py-2.5 text-xs text-slate-900 dark:text-white focus:outline-none focus:border-blue-500 transition-colors font-medium placeholder-slate-400" />
          </div>
          <div>
            <label class="block text-xs font-bold text-slate-500 uppercase tracking-wider mb-1.5 font-mono">Message Body</label>
            <textarea required rows="5" placeholder="Type your context paragraphs here..." class="w-full bg-slate-50 dark:bg-slate-950 border border-slate-200 dark:border-slate-800 rounded-xl px-3.5 py-2.5 text-xs text-slate-900 dark:text-white focus:outline-none focus:border-blue-500 transition-colors font-medium placeholder-slate-400 resize-none"></textarea>
          </div>
          <button type="submit" class="w-full bg-blue-600 hover:bg-blue-700 text-white font-bold text-xs uppercase tracking-widest py-3 rounded-xl shadow-md transition-colors cursor-pointer">
            Transmit Inquiry
          </button>
        </form>

        <div class="mt-8 border-t border-slate-100 dark:border-slate-800 pt-5 text-xs text-slate-400 space-y-1">
          <p class="font-bold text-slate-700 dark:text-slate-300">🏢 Direct Office Channels:</p>
          <p>Multi-Insight Portal Network Systems, Inc.</p>
          <p>Email Route: <span class="text-blue-500 select-all font-semibold">admin@multiinsightportal.pages.dev</span></p>
        </div>

      </div>
    </div>

    <!-- COLUMN 4: RIGHT PANEL SIDEBAR CONTAINER -->
    <aside class="md:col-span-1 lg:col-span-1 space-y-8 self-start md:sticky md:top-24">
      
      <!-- TRENDING CONTAINER -->
      <div class="bg-white dark:bg-slate-900 p-6 rounded-2xl border border-slate-200/60 dark:border-slate-800/60 shadow-sm relative overflow-hidden">
        <h2 class="text-md font-black uppercase tracking-wider text-slate-900 dark:text-white border-b border-slate-100 dark:border-slate-800 pb-3.5 mb-5 font-['Cabinet_Grotesk'] flex items-center gap-2">
          <span class="text-xl select-none">🔥</span> Trending
        </h2>
        <ul class="space-y-5">
          {trendingPosts.map((p, index) => (
            <li class="group cursor-pointer flex gap-3.5 items-start">
              <span class="text-xl font-black text-slate-200 dark:text-slate-700 group-hover:text-blue-600 dark:group-hover:text-blue-400 transition-colors leading-none font-['Cabinet_Grotesk']">
                {String(index + 1).padStart(2, '0')}
              </span>
              <div class="space-y-0.5">
                <h4 class="text-xs font-bold text-slate-800 dark:text-slate-200 leading-snug group-hover:underline">
                  <a href={`/posts/${p.id}`}>{p.data.title}</a>
                </h4>
                <span class="text-[9px] text-blue-600 dark:text-blue-400 font-extrabold uppercase tracking-widest block pt-0.5">
                  {p.data.category}
                </span>
              </div>
            </li>
          ))}
        </ul>
      </div>
    </aside>
  </div>

  <!-- BOTTOM FULL HORIZONTAL AD DISPLAY SLOT -->
  <div class="w-full bg-gradient-to-r from-slate-100 via-slate-50 to-slate-100 dark:from-slate-900 dark:via-slate-900 dark:to-slate-900 border border-dashed border-slate-300 dark:border-slate-800 rounded-2xl p-5 text-center mt-12 shadow-sm font-mono text-xs text-slate-400 select-none">
    [ GOOGLE ADSENSE — FOOTER HIGH-IMPRESSION NATIVE DISPLAY AD SLOT ]
  </div>
</BaseLayout>