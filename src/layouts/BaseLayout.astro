---
import '../styles/global.css';
import Header from '../components/Header.astro';
import Footer from '../components/Footer.astro';

const { title = "Multi-Insight Portal" } = Astro.props;
const canonicalFavicon = new URL('/favicon.svg', Astro.site || Astro.url).href;
---
<html lang="en">
	<head>
		<script is:inline>
			if (localStorage.getItem('color-theme') === 'dark' || (!('color-theme' in localStorage) && window.matchMedia('(prefers-color-scheme: dark)').matches)) {
				document.documentElement.classList.add('dark');
			} else {
				document.documentElement.classList.remove('dark');
			}
		</script>
		<meta charset="utf-8" />
		<!-- FORCE-BUST INTERACTIVE CACHE ROUTER -->
		<link rel="icon" type="image/svg+xml" href="/favicon.svg?v=updated2026" />
		<meta name="viewport" content="width=device-width, initial-scale=1.0" />
		<link rel="preconnect" href="https://googleapis.com">
		<link rel="preconnect" href="https://gstatic.com" crossorigin>
		<link href="https://googleapis.com/css2?family=Cabinet+Grotesk:wght@800;900&family=Inter:wght@400;500;600;700&display=swap" rel="stylesheet">
		<title>{title}</title>
	</head>
	
	<!-- Updated layout class tokens to listen to light/dark actions -->
	<body class="bg-[#F8FAFC] text-slate-900 dark:bg-slate-950 dark:text-slate-100 font-['Inter',sans-serif] antialiased transition-colors duration-200">

		
		<Header />
		
		<!-- Added the data-pagefind-body selector to isolate search indexing -->
		<main class="max-w-7xl mx-auto px-4 py-8" data-pagefind-body>
			<slot />
		</main>

		<Footer />

	</body>
</html>
