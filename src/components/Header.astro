---
const categories = ["Home", "Current Affairs", "Technology", ""Science", "Finance", "Social Studies", "About Us", "Contact Us"];
---
<div class="bg-blue-900 text-white text-xs font-semibold py-2 px-4 shadow-inner">
	<div class="max-w-7xl mx-auto flex items-center justify-between">
		<div class="flex items-center gap-2 overflow-hidden">
			<span class="bg-red-500 text-[10px] uppercase tracking-wider px-1.5 py-0.5 rounded font-bold animate-pulse">Live</span>
			<p class="truncate font-medium text-blue-100">Market Updates: Central banks signal shifting inflation baselines...</p>
		</div>
		<div class="hidden sm:block text-blue-200">Wednesday, July 15, 2026</div>
	</div>
</div>

<header class="bg-white border-b border-slate-200/80 sticky top-0 z-50 shadow-sm">
	<div class="max-w-7xl mx-auto px-4 py-5 flex flex-col items-center justify-between gap-4 md:flex-row">
		<a href="/" class="text-3xl font-['Cabinet_Grotesk',sans-serif] font-black tracking-tight text-slate-900 hover:text-blue-900 transition-colors">
			MULTI-INSIGHT <span class="text-blue-600">PORTAL</span>
		</a>
		<nav class="flex flex-wrap justify-center gap-2 text-xs font-bold tracking-wide uppercase">
			{categories.map((category) => (
				<a href={`/category/${category.toLowerCase()}`} class="px-3.5 py-2 rounded-full text-slate-600 bg-slate-50 hover:bg-blue-50 hover:text-blue-700 border border-slate-200/60 transition-all duration-200">
					{category}
				</a>
			))}
		</nav>
	</div>
</header>
