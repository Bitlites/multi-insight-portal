---
// Primary dynamic content tracking references
const categories = ["Current Affairs", "Technology", "Science", "Finance", "Social Studies"];
---

<footer class="bg-slate-900 dark:bg-slate-950 text-slate-400 text-sm mt-24 border-t border-slate-800 transition-colors duration-200">
	<div class="max-w-7xl mx-auto px-4 pt-16 pb-12">
		
		<!-- MAIN FOOTER GRID CONTAINER -->
		<div class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-4 gap-10 mb-12">
			
			<!-- COLUMN 1: BRANDING & BRIEF DESCRIPTION -->
			<div class="space-y-4">
				<!-- Wrapped entire block in an absolute hyperlink for full clickability -->
				<a href="/" class="flex items-center gap-2.5 tracking-tight group shrink-0 self-start">
					<!-- Mini Branding Icon (Added shrink-0 and aspect-square to guarantee true circle rendering bounds) -->
					<div class="w-8 h-8 rounded-lg bg-gradient-to-br from-blue-600 to-indigo-700 flex items-center justify-center text-white font-black text-md shadow-sm border border-blue-500/20 group-hover:scale-105 transition-transform duration-200 shrink-0 aspect-square">
						<svg xmlns="http://w3.org" fill="none" viewBox="0 0 24 24" stroke-width="2.5" stroke="currentColor" class="w-4 h-4">
							<path stroke-linecap="round" stroke-linejoin="round" d="M12 6.042A8.967 8.967 0 0 0 6 3.75c-1.052 0-2.062.18-3 .512v14.25A8.987 8.987 0 0 1 6 18c2.305 0 4.408.867 6 2.292m0-14.25a8.966 8.966 0 0 1 6-2.292c1.052 0 3 .512v14.25A8.987 8.987 0 0 0 18 18a8.967 8.967 0 0 0-6 2.292m0-14.25v14.25" />
						</svg>
					</div>
					<!-- Brand name text with group-hover matching your header styles -->
					<span class="text-lg font-black text-white tracking-tight group-hover:text-blue-400 transition-colors duration-200">
						MULTI-INSIGHT <span class="text-blue-500 group-hover:text-blue-300">PORTAL</span>
					</span>
				</a>
				<p class="text-xs text-slate-400 leading-relaxed font-normal">
					A data-first static intelligence dashboard. We deliver speed-optimized analyses across science, technology, financial indicators, and global structural shifts.
				</p>
			</div>

			<!-- COLUMN 2: HUB SECTIONS -->
			<div>
				<h3 class="text-xs font-bold uppercase tracking-wider text-slate-200 mb-4 font-mono">Content Categories</h3>
				<ul class="space-y-2.5 text-xs font-semibold">
					{categories.map((category) => (
						<li>
							<a 
								href={`/category/${category.toLowerCase().replace(/\s+/g, '-')}`} 
								class="hover:text-blue-400 dark:hover:text-blue-500 transition-colors duration-150 block">
								{category}
							</a>
						</li>
					))}
				</ul>
			</div>

			<!-- COLUMN 3: CORPORATE POLICIES (REQUIRED FOR GOOGLE ADSENSE) -->
			<div>
				<h3 class="text-xs font-bold uppercase tracking-wider text-slate-200 mb-4 font-mono">Legal & Compliance</h3>
				<ul class="space-y-2.5 text-xs font-semibold">
					<li><a href="/about" class="hover:text-blue-400 dark:hover:text-blue-500 transition-colors block">About Our Team</a></li>
					<li><a href="/contact" class="hover:text-blue-400 dark:hover:text-blue-500 transition-colors block">Connect / Support</a></li>
					<li><a href="/privacy-policy" class="hover:text-blue-400 dark:hover:text-blue-500 transition-colors block">Privacy Policy</a></li>
					<li><a href="/terms" class="hover:text-blue-400 dark:hover:text-blue-500 transition-colors block">Terms of Service</a></li>
					<li><a href="/cookie-policy" class="hover:text-blue-400 dark:hover:text-blue-500 transition-colors block">Cookie Disclosure</a></li>
				</ul>
			</div>

			<!-- COLUMN 4: AUDIENCE ENGAGEMENT ACCELERATOR -->
			<div class="space-y-4">
				<h3 class="text-xs font-bold uppercase tracking-wider text-slate-200 font-mono">Newsletter</h3>
				<p class="text-xs text-slate-400 leading-relaxed">
					Get static insight reports delivered straight to your terminal inbox every cycle.
				</p>
				<!-- Responsive capturing form panel mockup layout -->
				<form action="#" class="flex gap-2" onsubmit="event.preventDefault();">
					<input 
						type="email" 
						required 
						placeholder="Enter email address..." 
						class="w-full bg-slate-800 text-white rounded-lg px-3 py-2 text-xs border border-slate-700 focus:outline-none focus:border-blue-500 transition-colors placeholder-slate-500 font-medium"/>
					<button 
						type="submit" 
						class="bg-blue-600 hover:bg-blue-700 text-white font-bold px-3 py-2 rounded-lg text-xs tracking-wide uppercase transition-colors shrink-0 cursor-pointer">
						Join
					</button>
				</form>
			</div>
		</div>

		<!-- BOTTOM LICENSE SUBTERRANEAN BLOCK -->
		<div class="border-t border-slate-800 pt-8 flex flex-col sm:flex-row items-center justify-between gap-4 text-[11px] text-slate-500 font-medium font-sans">
			<div>
				&copy; {new Date().getFullYear()} Multi-Insight Portal. All rights reserved globally.
			</div>
			<div class="flex gap-4 text-slate-400">
				<span>Empowering Global Knowledge</span>
				<span>•</span>
				<span>Optimized Analyses</span>
			</div>

		</div>
	</div>
</footer>